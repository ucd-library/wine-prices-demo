# LDP / Digital Collections
LDP_HOST=https://digital.ucdavis.edu
COLLECTION_ARK=ark:/13030/c8pc37z3

# Samwise vLLM (OpenAI-compatible)
SAMWISE_BASE_URL=http://samwise.lib.ucdavis.edu:8000
SAMWISE_MODEL=qwen3.6-fast:35b
SAMWISE_API_KEY=

# PostgreSQL
DATABASE_URL=postgresql://wine:wine@localhost:5432/wine_prices

# Local image cache (mounted Docker volume path)
IMAGE_DIR=/data/images

# Optional: read page images from a GCS bucket instead of IMAGE_DIR.
# Object paths in the bucket match pages.image_path (<shortArk>/<filename>).
# Auth uses application default credentials (GOOGLE_APPLICATION_CREDENTIALS).
GCS_BUCKET=

# Search mode: 'simple' (trigram ILIKE over indexed text, default) or
# 'llm' (natural-language WHERE-clause generation via Samwise)
SEARCH_MODE=simple

# Concurrency
CRAWL_CONCURRENCY=3
EXTRACT_CONCURRENCY=2

# API server
PORT=3000
